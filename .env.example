# WOOWFLOW / ConnectFlow Hub - segredos de backend do Base44
#
# COMO USAR:
#   1. Preencha cada valor abaixo com credenciais NOVAS (as que passaram pelo chat devem ser revogadas).
#   2. Importe tudo de uma vez:   npx base44 secrets set --env-file .env.base44
#   3. Confira os nomes:          npx base44 secrets list
#   4. NAO versione este arquivo (mantenha no .gitignore).
#
# Os nomes abaixo tem que bater EXATAMENTE com os Deno.env.get(...) das functions.

# --- IXC (ERP) — usado por base44/functions/ixcApi ---
IXC_API_URL=https://sistema.cnnct.net.br/webservice/v1/
IXC_API_TOKEN=

# --- Valido Cadastro / Serasa — usado por base44/functions/serasaApi ---
SERASA_API_URL=https://api.validocadastro.com.br/json/service.aspx
SERASA_CHAVE_ACESSO=

# --- ZapSign (assinatura) — usado por base44/functions/zapsignApi ---
ZAPSIGN_API_TOKEN=

# --- WhatsApp / Evolution API — usado por base44/functions/evolutionApi ---
# (descomente e preencha quando for ativar o WhatsApp)
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE_NAME=
