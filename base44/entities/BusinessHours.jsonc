{
  "name": "BusinessHours",
  "type": "object",
  "properties": {
    "day": {
      "type": "string",
      "enum": [
        "segunda",
        "terca",
        "quarta",
        "quinta",
        "sexta",
        "sabado",
        "domingo"
      ]
    },
    "open_time": {
      "type": "string"
    },
    "close_time": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "day"
  ]
}